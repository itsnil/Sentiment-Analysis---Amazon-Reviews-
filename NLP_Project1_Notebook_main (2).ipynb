    {
      "cell_type": "code",
      "source": [
        "# Run for roBERTa Model\n",
        "def polarity_scores_roberta(example):\n",
        "  encoded_text = tokenizer(example, return_tensors = 'pt') ### pt = Formatting numerical arrays to PyTorch Tensors\n",
        "  output = model(**encoded_text)  ## Double Asterisk unpacks a dictionary\n",
        "  scores = output[0][0].detach().numpy()\n",
        "  scores = softmax(scores)\n",
        "  scores_dict = {\n",
        "      'roberta_neg' : scores[0],\n",
        "      'roberta_neu' : scores[1],\n",
        "      'roberta_pos' : scores[2]\n",
        "      }\n",
        "  return scores_dict"
      ],
      "metadata": {
        "id": "GQ5GtC3T_cW_"
      },
      "execution_count": 23,
      "outputs": []
    },
